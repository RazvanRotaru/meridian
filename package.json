{
  "name": "meridian-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @meridian/cli copy-renderer",
    "start": "node packages/cli/dist/bin.js web",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "schema:emit": "pnpm --filter @meridian/core schema:emit",
    "e2e": "pnpm build && pnpm --filter @meridian/cli copy-renderer && pnpm --filter @meridian/cli e2e"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
