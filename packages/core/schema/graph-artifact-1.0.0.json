{
  "$id": "https://meridian.dev/schema/graph-artifact/1.0.0.json",
  "title": "Meridian GraphArtifact 1.0.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.\\d+\\.\\d+$"
    },
    "generatedAt": {
      "type": "string"
    },
    "generator": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9+-]*$"
        },
        "vcs": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string"
            },
            "commit": {
              "type": "string"
            },
            "branch": {
              "type": "string"
            },
            "dirty": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "name",
        "root",
        "language"
      ],
      "additionalProperties": false
    },
    "telemetry": {
      "type": "object",
      "properties": {
        "joinKey": {
          "type": "string",
          "const": "node.id"
        },
        "requiredRuntimeAttributes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "serviceDefaulting": {
          "type": "string",
          "const": "forbidden"
        },
        "semconvVersion": {
          "type": "string"
        }
      },
      "required": [
        "joinKey",
        "requiredRuntimeAttributes",
        "serviceDefaulting"
      ],
      "additionalProperties": false
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*:[^#\\s]+(#[^#\\s]+)?(~\\d+)?$"
          },
          "kind": {
            "type": "string",
            "pattern": "^[a-z][a-zA-Z0-9]*$"
          },
          "qualifiedName": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "parentId": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*:[^#\\s]+(#[^#\\s]+)?(~\\d+)?$"
              },
              {
                "type": "null"
              }
            ]
          },
          "language": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9+-]*$"
          },
          "location": {
            "type": "object",
            "properties": {
              "file": {
                "type": "string"
              },
              "startLine": {
                "type": "integer",
                "minimum": 1,
                "maximum": 9007199254740991
              },
              "endLine": {
                "type": "integer",
                "minimum": 1,
                "maximum": 9007199254740991
              },
              "startCol": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "file",
              "startLine"
            ],
            "additionalProperties": false
          },
          "signature": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "telemetry": {
            "type": "object",
            "properties": {
              "codeNamespace": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "codeFunction": {
                "type": "string"
              },
              "spanNameHints": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "codeFunction",
              "spanNameHints"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "kind",
          "qualifiedName",
          "displayName",
          "location"
        ],
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9]+@[^|]+\\|.+$"
          },
          "source": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*:[^#\\s]+(#[^#\\s]+)?(~\\d+)?$"
          },
          "target": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*:[^#\\s]+(#[^#\\s]+)?(~\\d+)?$"
          },
          "kind": {
            "type": "string",
            "pattern": "^[a-z][a-zA-Z0-9]*$"
          },
          "resolution": {
            "type": "string",
            "enum": [
              "resolved",
              "external",
              "unresolved"
            ]
          },
          "weight": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "callSites": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file": {
                  "type": "string"
                },
                "line": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                },
                "col": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "file",
                "line"
              ],
              "additionalProperties": false
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "id",
          "source",
          "target",
          "kind"
        ],
        "additionalProperties": false
      }
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schemaVersion",
    "generatedAt",
    "generator",
    "target",
    "nodes",
    "edges"
  ],
  "additionalProperties": false
}
