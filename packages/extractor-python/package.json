{
  "name": "@meridian/extractor-python",
  "version": "0.1.0",
  "description": "The Python LanguageExtractor: a stdlib-ast analyzer plus a TS adapter that turns a Python tree into graph nodes + edges.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "python"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@meridian/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
