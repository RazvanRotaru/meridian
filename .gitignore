# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Generated blueprint artifacts (keep examples reproducible, ignore ad-hoc runs)
*.meridian.json
/tmp-graph.json
# Sample test-execution input is regenerated by `pnpm sample:coverage`.
/examples/orders-service/coverage/
# Default `generate` output name (and the --changed-since variant) — ad-hoc local runs
meridian.graph.json
meridian.graph*.json

# Renderer build (and the copy bundled into the CLI at pack time)
packages/renderer/dist/
packages/cli/renderer-dist/

# Python artifacts (the Python extractor ships .py source, not bytecode)
__pycache__/
*.pyc

# Editor / OS
.DS_Store
.idea/
.vscode/
*.log
